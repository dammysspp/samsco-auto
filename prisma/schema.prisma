datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// NextAuth standard models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  
  contentQueue     ContentQueue[]
  scheduleSettings ScheduleSettings?
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Custom Dashboard models
model ContentQueue {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title             String    // articleTitle
  description       String?   @db.Text
  sourceUrl         String?   // articleUrl
  articleSource     String?   // articleSource
  status            String    @default("draft") // draft, review_script, audio_generating, rendering_video, review_video, scheduled, publishing, posted, audio_failed, render_failed, publish_failed
  shortsScript      String?   @db.Text // script
  scriptVersions    String?   @db.Text // Store JSON representation of script versions
  communityCaption  String?   @db.Text
  voiceName         String?   @default("en-US-News-K")
  scheduledFor      DateTime?
  postedAt          DateTime? // publishedAt
  errorMessage      String?   @db.Text // lastError
  retryCount        Int       @default(0)

  // Cloud assets
  videoUrl          String?   @db.Text // renderUrl
  audioUrl          String?   @db.Text // audioUrl
  shotstackRenderId String?   @db.Text
  youtubeVideoId    String?   @db.Text
  youtubeUrl        String?   @db.Text

  // State-machine auditing timestamps
  scriptGeneratedAt   DateTime?
  scriptApprovedAt    DateTime?
  audioGeneratedAt    DateTime?
  renderSubmittedAt   DateTime?
  renderCompletedAt   DateTime?
  queuedAt            DateTime?
  publishingStartedAt DateTime?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model ScheduleSettings {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postingFrequency String   @default("DAILY") // DAILY, WEEKLY, MONTHLY
  preferredTime    String   @default("12:00") // HH:MM format in UTC
  youtubeChannelId String?
  groqApiKey       String?  @db.Text
  youtubeOAuth     String?  @db.Text // Store JSON representation of YouTube access/refresh token
  
  // New configuration fields stored in DB
  googleClientId      String?  @db.Text
  googleClientSecret  String?  @db.Text
  youtubeClientId     String?  @db.Text
  youtubeClientSecret String?  @db.Text
  youtubeRedirectUri  String?  @db.Text
  nextAuthUrl         String?  @db.Text
  cronSecret          String?  @db.Text
  apifyApiKey         String?  @db.Text
  shotstackApiKey     String?  @db.Text
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
