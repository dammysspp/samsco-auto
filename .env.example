# Database Config (PostgreSQL - e.g. Vercel Postgres or Supabase)
DATABASE_URL="postgresql://user:password@localhost:5432/fifa_world_cup_dashboard?schema=public"

# NextAuth Config (Run 'openssl rand -base64 32' to generate a secure secret)
NEXTAUTH_SECRET="your_nextauth_secret_here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth Credentials (for Dashboard Login)
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# Groq AI Inference Key
GROQ_API_KEY="gsk_your_groq_api_key_here"

# Vercel Cron Secret (for securing /api/cron/process-queue endpoint)
CRON_SECRET="your_cron_secret_phrase"

# YouTube Data API Credentials (Google Cloud OAuth)
YOUTUBE_CLIENT_ID="your_youtube_client_id.apps.googleusercontent.com"
YOUTUBE_CLIENT_SECRET="your_youtube_client_secret"
YOUTUBE_REDIRECT_URI="http://localhost:3000/api/auth/youtube/callback"
